<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.Pasantias" parent="Theme.Material3.Light.NoActionBar">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryDark">@color/primary_dark</item>
        <item name="colorSecondary">@color/secondary</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="android:statusBarColor">@color/secondary</item>
        <item name="android:navigationBarColor">@color/white</item>
        <item name="android:windowBackground">@color/neutral</item>
        <item name="materialButtonStyle">@style/Widget.Pasantias.Button</item>
    </style>

    <style name="Widget.Pasantias.Button" parent="Widget.Material3.Button">
        <item name="backgroundTint">@color/primary</item>
        <item name="android:textColor">@color/white</item>
        <item name="cornerRadius">8dp</item>
    </style>

    <style name="Widget.Pasantias.Toolbar" parent="Widget.Material3.Toolbar">
        <item name="android:background">@color/secondary</item>
        <item name="titleTextColor">@color/white</item>
    </style>

    <style name="Theme.Pasantias.ActionBar" parent="Theme.Pasantias">
        <item name="windowActionBar">true</item>
        <item name="windowNoTitle">false</item>
    </style>
</resources>
