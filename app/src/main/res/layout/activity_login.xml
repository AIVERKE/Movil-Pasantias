<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:paddingHorizontal="28dp"
        android:paddingTop="72dp"
        android:paddingBottom="32dp">

        <!-- Logo oficial del proyecto -->
        <ImageView
            android:layout_width="220dp"
            android:layout_height="80dp"
            android:src="@drawable/logotipo"
            android:scaleType="fitCenter"
            android:adjustViewBounds="true"
            android:layout_marginBottom="20dp" />

        <!-- Encabezado: "Iniciar Sesión" -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/login_heading"
            android:textColor="@color/secondary"
            android:textSize="26sp"
            android:textStyle="bold"
            android:gravity="center" />

        <!-- Subtítulo -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:layout_marginBottom="32dp"
            android:text="@string/login_subtitle"
            android:textColor="@color/text_muted"
            android:textSize="14sp"
            android:gravity="center" />

        <!-- Alerta de error -->
        <LinearLayout
            android:id="@+id/layoutError"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:background="@drawable/bg_error_alert"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="12dp"
            android:visibility="gone">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:id="@+id/textError"
                android:textColor="@color/danger"
                android:textSize="13sp" />
        </LinearLayout>

        <!-- Etiqueta: Correo -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="6dp"
            android:text="@string/email_hint"
            android:textColor="@color/secondary"
            android:textSize="13sp"
            android:textStyle="bold" />

        <!-- Campo: Email -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/layoutEmail"
            style="@style/Widget.Pasantias.TextInputLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="ejemplo@umsa.bo"
            app:startIconDrawable="@drawable/ic_email"
            app:boxBackgroundColor="@color/neutral"
            app:boxStrokeColor="@color/border_light"
            app:boxStrokeWidth="0dp"
            app:boxStrokeWidthFocused="2dp">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/inputEmail"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textEmailAddress"
                android:textSize="14sp" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Etiqueta: Contraseña -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="6dp"
            android:text="@string/password_hint"
            android:textColor="@color/secondary"
            android:textSize="13sp"
            android:textStyle="bold" />

        <!-- Campo: Contraseña -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/layoutPassword"
            style="@style/Widget.Pasantias.TextInputLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="••••••••"
            app:startIconDrawable="@drawable/ic_lock"
            app:endIconMode="password_toggle"
            app:boxBackgroundColor="@color/neutral"
            app:boxStrokeColor="@color/border_light"
            app:boxStrokeWidth="0dp"
            app:boxStrokeWidthFocused="2dp">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/inputPassword"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textPassword"
                android:textSize="14sp" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- ¿Olvidaste tu contraseña? -->
        <TextView
            android:id="@+id/textForgotPassword"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:gravity="end"
            android:text="@string/forgot_password"
            android:textColor="@color/secondary"
            android:textSize="13sp"
            android:textStyle="bold"
            android:clickable="true"
            android:focusable="true" />

        <!-- Botón: Iniciar Sesión -->
        <Button
            android:id="@+id/btnLogin"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="24dp"
            android:background="@drawable/selector_button_black"
            android:text="@string/login_button"
            android:textColor="@color/white"
            android:textSize="15sp"
            android:textStyle="bold"
            android:letterSpacing="0.02"
            android:stateListAnimator="@null" />

        <!-- ProgressBar (loading) -->
        <ProgressBar
            android:id="@+id/progressLogin"
            style="@android:style/Widget.Material.ProgressBar.Small"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:indeterminateTint="@color/secondary"
            android:visibility="gone" />

        <!-- Divisor -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="32dp"
            android:background="@color/border_light" />

        <!-- Footer: Crear cuenta -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:gravity="center"
            android:text="@string/no_account"
            android:textColor="@color/text_muted"
            android:textSize="14sp" />

    </LinearLayout>
</ScrollView>
