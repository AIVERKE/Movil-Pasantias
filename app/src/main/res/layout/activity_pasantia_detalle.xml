<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView android:id="@+id/textTitulo" android:layout_width="match_parent" android:layout_height="wrap_content" android:textColor="@color/secondary" android:textSize="22sp" android:textStyle="bold" />
    <TextView android:id="@+id/textEmpresa" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:textColor="@color/primary" />
    <TextView android:id="@+id/textDescripcion" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="12dp" android:textColor="@color/text_muted" />
    <TextView android:id="@+id/textMeta" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="12dp" />
    <com.google.android.material.button.MaterialButton android:id="@+id/btnPostular" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="24dp" android:text="@string/postular" />
    <ProgressBar android:id="@+id/progress" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_gravity="center" android:layout_marginTop="16dp" />
</LinearLayout>
