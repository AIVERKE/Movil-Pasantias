<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="12dp"
    android:layout_marginVertical="6dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="@color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <!-- Barra lateral de color según estado -->
        <View
            android:id="@+id/viewEstadoBar"
            android:layout_width="5dp"
            android:layout_height="match_parent"
            android:background="@color/estado_pendiente" />

        <!-- Contenido de la card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp">

            <!-- Fila superior: Título + Badge estado -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/tvTitulo"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="@color/secondary"
                    android:maxLines="2"
                    android:ellipsize="end"
                    android:text="Título de la pasantía" />

                <TextView
                    android:id="@+id/tvEstadoBadge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:paddingHorizontal="8dp"
                    android:paddingVertical="3dp"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:textColor="@color/white"
                    android:background="@drawable/bg_badge_estado"
                    android:text="Pendiente" />
            </LinearLayout>

            <!-- Área -->
            <TextView
                android:id="@+id/tvArea"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textSize="11sp"
                android:textColor="@color/text_muted"
                android:textAllCaps="true"
                android:letterSpacing="0.05"
                android:text="Área" />

            <!-- Descripción -->
            <TextView
                android:id="@+id/tvDescripcion"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:textSize="13sp"
                android:textColor="@color/text_muted"
                android:maxLines="2"
                android:ellipsize="end"
                android:lineSpacingMultiplier="1.3"
                android:text="Descripción de la pasantía..." />

            <!-- Sección de Mentores / Jefes -->
            <LinearLayout
                android:id="@+id/layoutMentoresContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="MENTORES ASIGNADOS"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_muted"
                    android:letterSpacing="0.05" />

                <!-- Lista de mentores -->
                <LinearLayout
                    android:id="@+id/layoutMentoresList"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginTop="4dp" />

                <!-- Botón Asignar Mentor -->
                <TextView
                    android:id="@+id/btnAsignarMentor"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:background="@drawable/bg_btn_assign_mentor"
                    android:textColor="@color/primary"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:paddingHorizontal="10dp"
                    android:paddingVertical="5dp"
                    android:drawableStart="@drawable/ic_plus_small"
                    android:drawablePadding="4dp"
                    android:gravity="center_vertical"
                    android:clickable="true"
                    android:focusable="true"
                    android:text="Asignar Mentor" />
            </LinearLayout>

            <!-- Divisor -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="10dp"
                android:layout_marginBottom="6dp"
                android:background="@color/border_light" />

            <!-- Fila de botones de acción -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <!-- Botón Actividades (izquierda) -->
                <LinearLayout
                    android:id="@+id/btnActividades"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@drawable/bg_btn_actividades"
                    android:paddingHorizontal="10dp"
                    android:paddingVertical="6dp"
                    android:clickable="true"
                    android:focusable="true">

                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:src="@drawable/ic_calendar_check"
                        android:layout_marginEnd="4dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Actividades"
                        android:textColor="@color/primary"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:layout_marginEnd="6dp" />

                    <TextView
                        android:id="@+id/tvActividadesCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_badge_count"
                        android:textColor="@color/primary"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:paddingHorizontal="6dp"
                        android:paddingVertical="2dp"
                        android:text="0" />
                </LinearLayout>

                <!-- Espaciador -->
                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1" />

                <!-- Editar (pendiente / en_curso) -->
                <ImageButton
                    android:id="@+id/btnEditar"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:padding="6dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@drawable/ic_pencil"
                    android:contentDescription="@string/edit"
                    android:tint="@color/primary"
                    android:visibility="gone" />

                <!-- Publicar (pendiente → en_curso) -->
                <ImageButton
                    android:id="@+id/btnPublicar"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:padding="6dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@drawable/ic_send"
                    android:contentDescription="@string/action_publicar"
                    android:tint="@color/estado_en_curso"
                    android:visibility="gone" />

                <!-- Pausar (en_curso → pendiente) -->
                <ImageButton
                    android:id="@+id/btnPausar"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:padding="6dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@drawable/ic_pause"
                    android:contentDescription="@string/action_pausar"
                    android:tint="@color/warning"
                    android:visibility="gone" />

                <!-- Finalizar (en_curso → finalizada) -->
                <ImageButton
                    android:id="@+id/btnFinalizar"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:padding="6dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@drawable/ic_check_circle"
                    android:contentDescription="@string/action_finalizar"
                    android:tint="@color/estado_finalizada"
                    android:visibility="gone" />

                <!-- Archivar (en_curso / finalizada → cancelada) -->
                <ImageButton
                    android:id="@+id/btnArchivar"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:padding="6dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@drawable/ic_archive"
                    android:contentDescription="@string/action_archivar"
                    android:tint="@color/estado_cancelada"
                    android:visibility="gone" />

                <!-- Reabrir (finalizada → en_curso) -->
                <ImageButton
                    android:id="@+id/btnReabrir"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:padding="6dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@drawable/ic_restore"
                    android:contentDescription="Reabrir"
                    android:tint="@color/primary"
                    android:visibility="gone" />

                <!-- Restaurar (cancelada → en_curso) -->
                <ImageButton
                    android:id="@+id/btnRestaurar"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:padding="6dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@drawable/ic_restore"
                    android:contentDescription="@string/action_restaurar"
                    android:tint="@color/primary"
                    android:visibility="gone" />

                <!-- Eliminar (solo pendiente) -->
                <ImageButton
                    android:id="@+id/btnEliminar"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:padding="6dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@drawable/ic_delete"
                    android:contentDescription="@string/delete"
                    android:tint="@color/danger"
                    android:visibility="gone" />

            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView>
