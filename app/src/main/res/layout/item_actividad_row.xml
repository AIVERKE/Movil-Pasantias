<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingVertical="10dp"
    android:background="@color/white">

    <!-- Indicador de Estado (Círculo con icono) -->
    <RelativeLayout
        android:id="@+id/layoutEstadoCircle"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:background="@drawable/bg_badge_estado"
        android:backgroundTint="#EBF5FF"
        android:layout_marginEnd="12dp">

        <ImageView
            android:id="@+id/imgEstadoIcon"
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:layout_centerInParent="true"
            android:src="@drawable/ic_calendar_check"
            android:tint="@color/primary" />
    </RelativeLayout>

    <!-- Detalles de la actividad -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvActDescripcion"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="14sp"
            android:textColor="@color/secondary"
            android:textStyle="bold"
            android:text="Descripción de la actividad" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="4dp"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tvActRangoFechas"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="11sp"
                android:textColor="@color/text_muted"
                android:text="01 Ene - 10 Ene" />

            <TextView
                android:id="@+id/tvActEstadoLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_badge_estado"
                android:backgroundTint="#F3F4F6"
                android:textColor="@color/text_muted"
                android:textSize="9sp"
                android:textStyle="bold"
                android:paddingHorizontal="6dp"
                android:paddingVertical="2dp"
                android:text="PENDIENTE" />
        </LinearLayout>
    </LinearLayout>

    <!-- Botones de Acción (Editar / Eliminar) -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginStart="8dp">

        <ImageButton
            android:id="@+id/btnEditarActividad"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_pencil"
            android:tint="@color/text_muted"
            android:padding="6dp"
            android:contentDescription="Editar" />

        <ImageButton
            android:id="@+id/btnEliminarActividad"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_delete"
            android:tint="@color/danger"
            android:padding="6dp"
            android:contentDescription="Eliminar" />
    </LinearLayout>

</LinearLayout>
